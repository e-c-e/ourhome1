{
  "pages": [
    "pages/auth/index",
    "pages/home/index",
    "pages/wall/index",
    "pages/anniversary/index",
    "pages/pet/index",
    "pages/wishes/index",
    "pages/my/index",
    "pages/message/index"
  ],
  "usingComponents": {
    "t-toast": "tdesign-miniprogram/toast/toast"
  },
  "subpackages": [
    {
      "root": "pages/release",
      "name": "release",
      "pages": ["index"]
    },
    {
      "root": "pages/moment",
      "name": "moment",
      "pages": ["detail"]
    }
  ],
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#fff",
    "navigationBarTitleText": "我们的空间",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "custom": true,
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/wall/index",
        "text": "时光墙"
      },
      {
        "pagePath": "pages/anniversary/index",
        "text": "纪念日"
      },
      {
        "pagePath": "pages/pet/index",
        "text": "宠物岛"
      },
      {
        "pagePath": "pages/wishes/index",
        "text": "心愿单"
      }
    ]
  },
  "resolveAlias": {
    "~/*": "/*"
  },
  "cloud": true,
  "sitemapLocation": "sitemap.json"
}
