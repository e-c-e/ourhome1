.warm-button {
  min-height: 96rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  overflow: hidden;
}

.warm-button--primary {
  color: #ffffff;
  background: linear-gradient(135deg, #FF8FA0 0%, #FFB2BE 100%);
  box-shadow: 0 16rpx 30rpx rgba(255, 158, 170, 0.24);
}

.warm-button--light {
  color: #B86E79;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 243, 246, 0.96) 100%);
  box-shadow: inset 0 0 0 2rpx rgba(255, 182, 193, 0.18), 0 10rpx 24rpx rgba(255, 182, 193, 0.1);
}

.warm-button--danger {
  color: #ffffff;
  background: linear-gradient(135deg, #F2949F 0%, #E87886 100%);
  box-shadow: 0 14rpx 28rpx rgba(232, 120, 134, 0.2);
}

.warm-button--danger-outline {
  color: #D56B78;
  background: rgba(255, 245, 246, 0.98);
  box-shadow: inset 0 0 0 2rpx rgba(240, 148, 159, 0.3), 0 8rpx 20rpx rgba(240, 148, 159, 0.08);
}