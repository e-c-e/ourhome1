.warm-button {
  min-height: 96rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1.2rpx;
  overflow: hidden;
  position: relative;
  backdrop-filter: blur(18rpx) saturate(118%);
  -webkit-backdrop-filter: blur(18rpx) saturate(118%);
}

.warm-button::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
}

.warm-button--primary {
  color: #ffffff;
  background: linear-gradient(135deg, rgba(255, 126, 158, 0.72) 0%, rgba(255, 149, 175, 0.66) 48%, rgba(255, 185, 199, 0.6) 100%);
  box-shadow: 0 16rpx 34rpx rgba(255, 137, 164, 0.14), inset 0 0 0 2rpx rgba(255, 238, 242, 0.18);
}

.warm-button--primary::before {
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.14), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.05) 44%, rgba(255, 255, 255, 0) 100%);
}

.warm-button--light {
  color: #af6277;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.58) 0%, rgba(255, 247, 250, 0.44) 52%, rgba(255, 237, 242, 0.48) 100%);
  box-shadow: 0 14rpx 28rpx rgba(236, 194, 203, 0.12), inset 0 0 0 2rpx rgba(255, 255, 255, 0.16);
}

.warm-button--light::before {
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 22%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.12) 0%, rgba(255, 232, 239, 0.03) 100%);
}

.warm-button--danger {
  color: #ffffff;
  background: linear-gradient(135deg, rgba(240, 139, 155, 0.76) 0%, rgba(233, 115, 136, 0.68) 100%);
  box-shadow: 0 14rpx 30rpx rgba(232, 120, 134, 0.14), inset 0 0 0 2rpx rgba(255, 236, 239, 0.16);
}

.warm-button--danger::before {
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.14) 0%, rgba(255, 255, 255, 0.04) 44%, rgba(255, 255, 255, 0) 100%);
}

.warm-button--danger-outline {
  color: #D56B78;
  background: linear-gradient(135deg, rgba(255, 247, 248, 0.78) 0%, rgba(255, 241, 244, 0.72) 100%);
  box-shadow: inset 0 0 0 2rpx rgba(240, 148, 159, 0.18), 0 10rpx 22rpx rgba(240, 148, 159, 0.08);
}

.warm-button--fixed-surface {
  border-radius: 40rpx;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.warm-button--fixed-surface::before {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.08) 18%, rgba(255, 255, 255, 0) 42%);
}

.warm-button--fixed-surface.warm-button--primary {
  background: linear-gradient(180deg, #ffb2bc 0%, #fb95a4 16%, #f18395 100%);
  box-shadow: 0 16rpx 30rpx rgba(223, 126, 142, 0.2), inset 0 2rpx 0 rgba(255, 246, 248, 0.54), inset 0 0 0 2rpx rgba(245, 216, 222, 0.32);
}

.warm-button--fixed-surface.warm-button--primary::before {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0.08) 20%, rgba(255, 255, 255, 0) 42%);
}

.warm-button--fixed-surface.warm-button--light {
  color: #9d6771;
  background: linear-gradient(180deg, rgba(255, 252, 251, 0.98) 0%, rgba(255, 245, 243, 0.96) 100%);
  box-shadow: 0 12rpx 24rpx rgba(208, 171, 176, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.72), inset 0 0 0 2rpx rgba(235, 213, 216, 0.54);
}

.warm-button--fixed-surface.warm-button--danger {
  background: linear-gradient(180deg, #f7a1ad 0%, #ea7f90 100%);
  box-shadow: 0 16rpx 28rpx rgba(219, 115, 131, 0.2), inset 0 2rpx 0 rgba(255, 244, 246, 0.48), inset 0 0 0 2rpx rgba(240, 213, 218, 0.3);
}

.warm-button--fixed-surface.warm-button--danger-outline {
  color: #c96d7a;
  background: linear-gradient(180deg, rgba(255, 252, 251, 0.98) 0%, rgba(255, 244, 245, 0.96) 100%);
  box-shadow: 0 12rpx 24rpx rgba(208, 171, 176, 0.1), inset 0 2rpx 0 rgba(255, 255, 255, 0.7), inset 0 0 0 2rpx rgba(233, 195, 201, 0.46);
}