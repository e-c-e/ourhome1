.warm-status-card {
  padding: 32rpx 28rpx;
  text-align: center;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 249, 250, 0.9) 100%);
  box-shadow: 0 18rpx 42rpx rgba(255, 182, 193, 0.12), inset 0 0 0 2rpx rgba(255, 255, 255, 0.34);
}

.warm-status-card--error {
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.62), transparent 26%),
    linear-gradient(180deg, rgba(255, 244, 246, 0.96) 0%, rgba(255, 239, 242, 0.94) 100%);
}

.warm-status-card__title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #5C4B3A;
}

.warm-status-card__desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: rgba(92, 75, 58, 0.6);
}