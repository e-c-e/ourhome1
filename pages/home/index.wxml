<warm-navbar title="我们的空间"></warm-navbar>

<view class="home-page warm-fade-page">
  <view class="home-bg" aria-hidden="true">
    <view class="home-bg__veil"></view>
    <view class="home-bg__glow home-bg__glow--top"></view>
    <view class="home-bg__cloud home-bg__cloud--left"></view>
    <view class="home-bg__cloud home-bg__cloud--right"></view>
    <text class="home-bg__heart home-bg__heart--one">❤</text>
    <text class="home-bg__heart home-bg__heart--two">❤</text>
    <view class="home-bg__side home-bg__side--left">
      <text class="home-bg__sticker home-bg__sticker--bow">🎀</text>
      <text class="home-bg__sticker home-bg__sticker--spark">✦</text>
    </view>
    <view class="home-bg__side home-bg__side--right">
      <text class="home-bg__sticker home-bg__sticker--flower">❀</text>
      <text class="home-bg__sticker home-bg__sticker--ribbon">⌒❤⌒</text>
    </view>
    <view class="home-bg__bottom">
      <text class="home-bg__bottom-item home-bg__bottom-item--moon">☾</text>
      <text class="home-bg__bottom-item home-bg__bottom-item--cloud-left">☁</text>
      <text class="home-bg__bottom-item home-bg__bottom-item--cloud-right">☁</text>
      <text class="home-bg__bottom-item home-bg__bottom-item--star">✧</text>
    </view>
  </view>

  <view class="home-content">
  <view class="hero-card">
    <view class="hero-card__eyebrow">❤️ 只属于我们的空间</view>
    <view class="hero-card__title">把日常慢慢写成回忆</view>
    <view class="hero-card__desc">
      记录每一次见面、每一段话、每一张照片，让属于你们的日子有迹可循。
    </view>
    <view class="hero-card__badge">🌸 今天也要好好相爱</view>

    <view class="hero-stats">
      <view class="stat-box">
        <text class="stat-box__icon">💞</text>
        <text class="stat-box__value">{{relationshipDays}}</text>
        <text class="stat-box__label">❤️ 在一起天数</text>
      </view>
      <view class="stat-box">
        <text class="stat-box__icon">📸</text>
        <text class="stat-box__value">{{momentCount}}</text>
        <text class="stat-box__label">🌸 回忆条数</text>
      </view>
      <view class="stat-box">
        <text class="stat-box__icon">✨</text>
        <text class="stat-box__value">{{latestMood}}</text>
        <text class="stat-box__label">🐾 最近心情</text>
      </view>
    </view>

    <view class="hero-actions">
      <view class="hero-actions__item">
        <warm-button theme="primary" size="large" block="{{true}}" bind:action="goRelease">❤️ 记录今天</warm-button>
      </view>
    </view>
  </view>

  <warm-empty-state wx:if="{{loading}}" customClass="home-empty home-empty--soft" title="🌷 正在整理回忆..." desc="等一下，就把属于你们的内容放出来。"></warm-empty-state>

  <warm-empty-state wx:elif="{{errorMessage}}" customClass="home-empty home-empty--soft" title="💭 加载失败" desc="{{errorMessage}}"></warm-empty-state>

  <block wx:elif="{{recentMoments.length}}">
    <view class="section-panel section-panel--memory-list">
      <view class="section-head">
        <text class="section-head__title">🌸 最近回忆</text>
        <text class="section-head__sub">共 {{recentMoments.length}} 条</text>
      </view>

      <view class="memory-feed">
        <view wx:for="{{recentMoments}}" wx:key="id" class="memory-entry {{!item.previewImages.length && !item.cover ? 'memory-entry--text-only' : ''}}" data-id="{{item.id}}" bindtap="goMomentDetail">
          <view class="memory-entry__gallery" wx:if="{{item.previewImages.length}}">
            <image
              wx:for="{{item.previewImages}}"
              wx:key="*this"
              class="memory-entry__thumb"
              src="{{item}}"
              mode="aspectFill"
              data-images="{{item.previewImages}}"
              data-current="{{item}}"
              catchtap="previewMomentImages"
            />
          </view>
          <view wx:elif="{{item.cover}}" class="memory-entry__cover-wrap">
            <image class="memory-entry__cover" src="{{item.cover}}" mode="aspectFill" />
          </view>
          <view wx:else class="memory-entry__placeholder">
            <view class="memory-entry__placeholder-row">
              <text class="memory-entry__placeholder-icon">💌</text>
              <text class="memory-entry__placeholder-icon memory-entry__placeholder-icon--soft">✿</text>
            </view>
            <view class="memory-entry__placeholder-title">这是一条只用文字写下的回忆</view>
            <view class="memory-entry__placeholder-desc">没有照片也没关系，心动的小瞬间本来就值得被记住。</view>
          </view>

          <view class="memory-entry__body">
            <view class="memory-entry__row">
              <text class="memory-entry__date">{{item.date}}</text>
              <text class="memory-entry__mood">💗 {{item.mood}}</text>
            </view>
            <view class="memory-entry__title">{{item.title}}</view>
            <view class="memory-entry__text">{{item.content}}</view>
            <view wx:if="{{item.locationText}}" class="memory-entry__footer">
              <text class="memory-entry__location">📍 {{item.locationText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="warm-page-end"></view>
  </block>

  <block wx:else>
    <warm-empty-state customClass="home-empty" title="💕 还没有记录" desc="点下方按钮，写下第一条属于你们的回忆。"></warm-empty-state>
    <view class="warm-page-end"></view>
  </block>


  </view>
</view>