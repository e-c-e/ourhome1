<warm-navbar title="我们的空间"></warm-navbar>

<view class="home-page warm-fade-page">
  <view class="home-bg" aria-hidden="true">
    <view class="home-bg__veil"></view>
    <view class="home-bg__glow home-bg__glow--top"></view>
    <view class="home-bg__cloud home-bg__cloud--left"></view>
    <view class="home-bg__cloud home-bg__cloud--right"></view>
    <text class="home-bg__heart home-bg__heart--one">❤</text>
    <text class="home-bg__heart home-bg__heart--two">❤</text>
    <view class="home-bg__side home-bg__side--left">
      <text class="home-bg__sticker home-bg__sticker--bow">🎀</text>
      <text class="home-bg__sticker home-bg__sticker--spark">✦</text>
    </view>
    <view class="home-bg__side home-bg__side--right">
      <text class="home-bg__sticker home-bg__sticker--flower">❀</text>
      <text class="home-bg__sticker home-bg__sticker--ribbon">⌒❤⌒</text>
    </view>
    <view class="home-bg__bottom">
      <text class="home-bg__bottom-item home-bg__bottom-item--moon">☾</text>
      <text class="home-bg__bottom-item home-bg__bottom-item--cloud-left">☁</text>
      <text class="home-bg__bottom-item home-bg__bottom-item--cloud-right">☁</text>
      <text class="home-bg__bottom-item home-bg__bottom-item--star">✧</text>
    </view>
  </view>

  <view class="home-content">
  <view class="hero-card">
    <view class="hero-card__eyebrow">❤️ 只属于我们的空间</view>
    <view class="hero-card__title">把日常慢慢写成回忆</view>
    <view class="hero-card__desc">
      记录每一次见面、每一段话、每一张照片，让属于你们的日子有迹可循。
    </view>
    <view class="hero-card__badge">🌸 今天也要好好相爱</view>

    <view class="hero-stats">
      <view class="stat-box">
        <text class="stat-box__icon">💞</text>
        <text class="stat-box__value">{{relationshipDays}}</text>
        <text class="stat-box__label">❤️ 在一起天数</text>
      </view>
      <view class="stat-box">
        <text class="stat-box__icon">📸</text>
        <text class="stat-box__value">{{momentCount}}</text>
        <text class="stat-box__label">🌸 回忆条数</text>
      </view>
      <view class="stat-box">
        <text class="stat-box__icon">✨</text>
        <text class="stat-box__value">{{latestMood}}</text>
        <text class="stat-box__label">🐾 最近心情</text>
      </view>
    </view>

    <view class="hero-actions">
      <view class="hero-actions__item">
        <warm-button theme="primary" size="large" block="{{true}}" bind:action="goRelease">❤️ 记录今天</warm-button>
      </view>
    </view>
  </view>

  <warm-empty-state wx:if="{{loading}}" customClass="home-empty home-empty--soft" title="🌷 正在整理回忆..." desc="等一下，就把属于你们的内容放出来。"></warm-empty-state>

  <warm-empty-state wx:elif="{{errorMessage}}" customClass="home-empty home-empty--soft" title="💭 加载失败" desc="{{errorMessage}}"></warm-empty-state>

  <block wx:else>
    <view class="section-panel status-panel">
      <view class="section-head section-head--single">
        <text class="section-head__title">🌷 今日状态</text>
        <text class="section-head__sub">今天适合做什么</text>
      </view>

      <view class="status-grid">
        <view class="status-card status-card--visit">
          <view class="status-card__head">
            <view class="status-card__icon">👣</view>
            <view class="status-card__label">今天谁何时来过</view>
          </view>
          <view class="status-card__title">{{homeSnapshot.partnerVisit.title}}</view>
          <view class="status-card__desc">{{homeSnapshot.partnerVisit.desc}}</view>
          <view wx:if="{{homeSnapshot.partnerVisit.items.length}}" class="visit-list">
            <view wx:for="{{homeSnapshot.partnerVisit.items}}" wx:key="id" class="visit-item">
              <text class="visit-item__badge">{{item.dayLabel}}</text>
              <text class="visit-item__text">{{item.timeText}} · {{item.routeLabel}}</text>
            </view>
          </view>
        </view>

        <view class="status-card status-card--tip" bindtap="goTipsPage">
          <view class="status-card__head">
            <view class="status-card__icon">🥤</view>
            <view class="status-card__label">今天的小提示</view>
          </view>
          <view class="status-card__title">把今天过得舒服一点</view>
          <view class="status-card__desc">{{homeSnapshot.dailyTip}}</view>
          <view wx:if="{{!tipEditorVisible}}" class="status-card__action" catchtap="openTipEditor">直接在首页编辑</view>
          <view wx:if="{{tipEditorVisible}}" class="tip-editor" catchtap="noop">
            <textarea class="tip-editor__textarea" maxlength="240" placeholder="一行写一条提示，留空则使用系统默认提示" value="{{dailyTipDraft}}" bindinput="handleTipDraftInput"></textarea>
            <view class="tip-editor__note">一行一条，首页会按日期轮换显示。</view>
            <view class="tip-editor__actions">
              <view class="tip-editor__button tip-editor__button--ghost" catchtap="cancelTipEditor">取消</view>
              <view class="tip-editor__button" catchtap="saveHomeTips">{{tipSaving ? '保存中...' : '保存提示'}}</view>
            </view>
          </view>
        </view>

        <view class="status-card status-card--anniversary">
          <view class="status-card__head">
            <view class="status-card__icon">📅</view>
            <view class="status-card__label">纪念日倒数</view>
          </view>
          <view class="status-card__title">{{homeSnapshot.anniversary.title}}</view>
          <view class="status-card__desc">{{homeSnapshot.anniversary.desc}}</view>
        </view>

        <view class="status-card status-card--activity">
          <view class="status-card__head">
            <view class="status-card__icon">💌</view>
            <view class="status-card__label">对方最近动态</view>
          </view>
          <view class="status-card__title">{{homeSnapshot.latestActivity.title}}</view>
          <view class="status-card__desc">{{homeSnapshot.latestActivity.desc}}</view>
          <view wx:if="{{homeSnapshot.latestActivity.items.length}}" class="activity-list">
            <view wx:for="{{homeSnapshot.latestActivity.items}}" wx:key="id" class="activity-item">
              <text class="activity-item__badge">{{item.badge}}</text>
              <text class="activity-item__text">{{item.timeText}} · {{item.title}}</text>
            </view>
          </view>
          <view class="status-card__action" bindtap="goActivityFeed">查看完整动态</view>
        </view>
      </view>
    </view>

    <view class="notice-panel">
      <view class="notice-panel__head">
        <view>
          <view class="notice-panel__title">🔔 提醒中心</view>
          <view class="notice-panel__desc">记录今天和记录这一天保存成功后，会从同一个云端入口触发提醒。</view>
        </view>
        <view wx:if="{{unreadNotificationCount}}" class="notice-panel__count">{{unreadNotificationCount}}</view>
      </view>

      <view class="notice-panel__subscribe">
        <view>
          <view class="notice-panel__subscribe-title">微信提醒</view>
          <view class="notice-panel__subscribe-desc">{{momentNotificationText}}</view>
        </view>
        <view class="notice-panel__subscribe-action" bindtap="enableMomentNotification">
          {{momentNotification.enabled ? '重新授权' : '开启提醒'}}
        </view>
      </view>

      <view wx:if="{{notifications.length}}" class="notice-list">
        <view wx:for="{{notifications}}" wx:key="id" class="notice-item {{!item.isRead ? 'notice-item--unread' : ''}}" data-id="{{item.id}}" data-moment-id="{{item.momentId}}" data-is-read="{{item.isRead}}" bindtap="handleNotificationTap">
          <view class="notice-item__main">
            <view class="notice-item__title-row">
              <text class="notice-item__title">{{item.title}}</text>
              <text class="notice-item__time">{{item.createdAtText}}</text>
            </view>
            <view class="notice-item__content">{{item.content}}</view>
          </view>
        </view>
        <view wx:if="{{unreadNotificationCount}}" class="notice-panel__footer">
          <view class="notice-panel__mark" bindtap="markAllNotificationsRead">全部标记已读</view>
        </view>
      </view>
      <view wx:else class="notice-panel__empty">对方发布新记录后，站内提醒会先显示在这里。</view>
    </view>

    <view class="warm-page-end"></view>
  </block>

  </view>
</view>