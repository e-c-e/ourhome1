<warm-navbar title="心愿花园"></warm-navbar>

<view class="wish-page warm-fade-page">
  <view class="wish-bg" aria-hidden="true">
    <view class="wish-bg__veil"></view>
    <view class="wish-bg__glow wish-bg__glow--top"></view>
    <view class="wish-bg__glow wish-bg__glow--bottom"></view>
    <view class="wish-bg__clouds">
      <text class="wish-bg__cloud wish-bg__cloud--a">☁</text>
      <text class="wish-bg__cloud wish-bg__cloud--b">☁</text>
      <text class="wish-bg__cloud wish-bg__cloud--c">☁</text>
    </view>
    <view class="wish-bg__side wish-bg__side--left">
      <text class="wish-bg__float wish-bg__float--left-bow">🎀</text>
      <text class="wish-bg__float wish-bg__float--left-star">✦</text>
      <text class="wish-bg__float wish-bg__float--left-heart">❤</text>
    </view>
    <view class="wish-bg__side wish-bg__side--right">
      <text class="wish-bg__float wish-bg__float--right-flower">❀</text>
      <text class="wish-bg__float wish-bg__float--right-spark">✧</text>
      <text class="wish-bg__float wish-bg__float--right-ribbon">⌒❤⌒</text>
    </view>
    <view class="wish-bg__bottom">
      <text class="wish-bg__bottom-item wish-bg__bottom-item--grass-l">🌿</text>
      <text class="wish-bg__bottom-item wish-bg__bottom-item--grass-r">🌿</text>
      <text class="wish-bg__bottom-item wish-bg__bottom-item--moon">☾</text>
      <text class="wish-bg__bottom-item wish-bg__bottom-item--garland">✦ ･ﾟ* ✧ ･ﾟ* ✦</text>
      <text class="wish-bg__bottom-item wish-bg__bottom-item--cloud-left">☁</text>
      <text class="wish-bg__bottom-item wish-bg__bottom-item--cloud-right">☁</text>
      <text class="wish-bg__bottom-item wish-bg__bottom-item--star">✧</text>
    </view>
  </view>

  <view class="wish-content">
    <warm-status-card wx:if="{{loading}}" title="🌸 正在整理心愿" desc="把想一起完成的小事和大事慢慢排出来。"></warm-status-card>
    <warm-status-card wx:elif="{{errorMessage}}" error="{{true}}" title="💭 加载失败" desc="{{errorMessage}}"></warm-status-card>

    <block wx:else>
      <!-- Garden Header with Progress -->
      <view class="garden-header">
        <view class="garden-header__eyebrow">🌿 心愿花园</view>
        <view class="garden-header__title">把想一起实现的未来，轻轻种进这里</view>
        <view class="garden-header__desc">{{heroTip}}</view>

        <view class="garden-progress">
          <view class="garden-progress__text">{{progressText}}</view>
          <view class="garden-progress__track">
            <view class="garden-progress__fill" style="width: {{summary.completionRate}}%">
              <text wx:if="{{summary.completionRate > 0}}" class="garden-progress__petal">🌸</text>
            </view>
          </view>
        </view>

        <view class="garden-stats">
          <view class="garden-stat">
            <text class="garden-stat__icon">🌱</text>
            <text class="garden-stat__val">{{summary.pending}}</text>
            <text class="garden-stat__lbl">待浇灌</text>
          </view>
          <view class="garden-stat__sep"></view>
          <view class="garden-stat">
            <text class="garden-stat__icon">🌸</text>
            <text class="garden-stat__val">{{summary.completed}}</text>
            <text class="garden-stat__lbl">已盛开</text>
          </view>
          <view class="garden-stat__sep"></view>
          <view class="garden-stat">
            <text class="garden-stat__icon">✨</text>
            <text class="garden-stat__val">{{summary.total}}</text>
            <text class="garden-stat__lbl">心愿总数</text>
          </view>
        </view>
      </view>

      <!-- Next Wish Hint -->
      <view wx:if="{{nextWish}}" class="next-wish-hint">
        <text class="next-wish-hint__icon">💌</text>
        <text class="next-wish-hint__text">下一个想完成：{{nextWish}}</text>
      </view>

      <!-- Add Wish Panel -->
      <view class="panel">
        <view class="panel__title">🌱 种下新的心愿</view>
        <view class="panel__desc">可以是看海、旅行、做一顿饭，或者只是想一起度过的普通傍晚。</view>
        <view class="editor-shell">
          <warm-input
            customClass="field-input"
            value="{{wishText}}"
            placeholder="例如：一起去吹海风看日落"
            maxlength="40"
            bind:input="handleWishInput"
          ></warm-input>
          <view class="editor-shell__action">
            <warm-button theme="primary" size="large" bind:action="addWish">🌿 种下心愿</warm-button>
          </view>
        </view>
      </view>

      <!-- Flower Garden Grid -->
      <block wx:if="{{wishes.length}}">

        <!-- Pending Section -->
        <view wx:if="{{summary.pending > 0}}" class="garden-section">
          <view class="garden-section__hd">
            <text class="garden-section__label">🌱 正在期待的小芽</text>
            <text class="garden-section__count">{{summary.pending}} 颗</text>
          </view>
          <view class="garden-bed garden-bed--seed">
          <view class="garden-bed__edge garden-bed__edge--fence"></view>
          <view class="garden-bed__decor garden-bed__decor--can">🪴</view>
          <view class="garden-bed__decor garden-bed__decor--sign">待开花</view>
          <view class="flower-grid">
            <block wx:for="{{wishes}}" wx:key="id">
              <view wx:if="{{!item.isCompleted}}" class="flower-pot flower-pot--seed flower-pot--s{{item.potStyle}} flower-pot--lane{{item.gardenLane}} flower-pot--h{{item.gardenHeight}}">
                <view class="flower-pot__plant">
                  <text class="flower-pot__emoji">🌱</text>
                </view>
                <view class="flower-pot__shell">
                  <view class="flower-pot__rim"></view>
                  <view class="flower-pot__soil"></view>
                  <view class="flower-pot__body">
                    <view class="flower-pot__label flower-pot__label--seed">待浇灌</view>
                    <view class="flower-pot__content">{{item.content}}</view>
                  </view>
                </view>
                <view class="flower-pot__actions flower-pot__actions--hang">
                  <text class="flower-pot__btn flower-pot__btn--done" data-id="{{item.id}}" bindtap="toggleWish">✓ 完成</text>
                  <text class="flower-pot__btn flower-pot__btn--del" data-id="{{item.id}}" bindtap="removeWish">移除</text>
                </view>
              </view>
            </block>
          </view>
          <view class="garden-bed__grass">🌿 🌱 🌿 🌱 🌿</view>
          </view>
        </view>

        <!-- Completed Section -->
        <view wx:if="{{summary.completed > 0}}" class="garden-section">
          <view class="garden-section__hd">
            <text class="garden-section__label">🌸 已经盛开的小花</text>
            <text class="garden-section__count">{{summary.completed}} 朵</text>
          </view>
          <view class="garden-bed garden-bed--bloom">
          <view class="garden-bed__edge garden-bed__edge--stone"></view>
          <view class="garden-bed__decor garden-bed__decor--corner">◦ ◦ ◦</view>
          <view class="garden-bed__decor garden-bed__decor--petal">✿</view>
          <view class="flower-grid">
            <block wx:for="{{wishes}}" wx:key="id">
              <view wx:if="{{item.isCompleted}}" class="flower-pot flower-pot--bloom flower-pot--lane{{item.gardenLane}} flower-pot--h{{item.gardenHeight}} {{item.isFirstBloom ? 'flower-pot--first' : ''}}">
                <view wx:if="{{item.isFirstBloom}}" class="flower-pot__crown">🎀 第一朵花</view>
                <view class="flower-pot__plant flower-pot__plant--bloom">
                  <text class="flower-pot__emoji">{{item.flowerEmoji}}</text>
                </view>
                <view class="flower-pot__shell flower-pot__shell--bloom">
                  <view class="flower-pot__rim flower-pot__rim--bloom"></view>
                  <view class="flower-pot__soil flower-pot__soil--bloom"></view>
                  <view class="flower-pot__body flower-pot__body--bloom">
                    <view class="flower-pot__label flower-pot__label--bloom">心愿达成💐</view>
                    <view class="flower-pot__content">{{item.content}}</view>
                    <view wx:if="{{item.completedTime}}" class="flower-pot__date">完成于 {{item.completedTime}}</view>
                  </view>
                </view>
                <view class="flower-pot__actions flower-pot__actions--hang">
                  <text class="flower-pot__btn flower-pot__btn--undo" data-id="{{item.id}}" bindtap="toggleWish">撤销</text>
                  <text class="flower-pot__btn flower-pot__btn--del" data-id="{{item.id}}" bindtap="removeWish">移除</text>
                </view>
              </view>
            </block>
          </view>
          <view class="garden-bed__grass garden-bed__grass--bloom">🌷 🌿 🌸 🌿 🌼</view>
          </view>
        </view>

      </block>

      <!-- Empty State -->
      <view wx:else class="garden-empty">
        <view class="garden-empty__art">
          <view class="garden-empty__clouds-row">
            <text class="garden-empty__cloud">☁</text>
            <text class="garden-empty__cloud garden-empty__cloud--sm">☁</text>
          </view>
          <view class="garden-empty__pots-row">
            <view class="garden-empty__pot-card">
              <text class="garden-empty__pot-emoji">🪴</text>
            </view>
          </view>
          <view class="garden-empty__grass-row">
            <text>🌿</text>
            <text>🌿</text>
            <text>🌿</text>
          </view>
        </view>
        <view class="garden-empty__title">空空的小花圃</view>
        <view class="garden-empty__desc">还没有种下心愿哦，和宝一起种一朵属于你们的小花吧～</view>
      </view>

      <view class="warm-page-end"></view>
    </block>
  </view>
</view>
