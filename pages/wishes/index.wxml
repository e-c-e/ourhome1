<warm-navbar title="心愿树"></warm-navbar>

<view class="wish-page warm-fade-page">
  <view class="wish-bg" aria-hidden="true">
    <view class="wish-bg__veil"></view>
    <view class="wish-bg__glow wish-bg__glow--top"></view>
    <view class="wish-bg__glow wish-bg__glow--bottom"></view>
    <text class="wish-bg__cloud wish-bg__cloud--left">☁</text>
    <text class="wish-bg__cloud wish-bg__cloud--right">☁</text>
    <text class="wish-bg__spark wish-bg__spark--a">✦</text>
    <text class="wish-bg__spark wish-bg__spark--b">✧</text>
    <text class="wish-bg__spark wish-bg__spark--c">✦</text>
  </view>

  <view class="wish-content">
    <warm-status-card wx:if="{{loading}}" title="🌿 心愿树正在长叶子" desc="把已经成熟的果实和还在等待的花苞慢慢挂好。"></warm-status-card>
    <warm-status-card wx:elif="{{errorMessage}}" error="{{true}}" title="💭 加载失败" desc="{{errorMessage}}"></warm-status-card>

    <block wx:else>
      <view class="tree-header">
        <view class="tree-header__eyebrow">🌳 心愿树</view>
        <view class="tree-header__title">把想一起完成的未来，挂在会成长的树上</view>
        <view class="tree-header__desc">{{heroTip}}</view>

        <view class="tree-stats">
          <view class="tree-stat">
            <text class="tree-stat__value">{{summary.pending}}</text>
            <text class="tree-stat__label">花苞</text>
          </view>
          <view class="tree-stat">
            <text class="tree-stat__value">{{summary.ripe}}</text>
            <text class="tree-stat__label">树上果实</text>
          </view>
          <view class="tree-stat">
            <text class="tree-stat__value">{{summary.stored}}</text>
            <text class="tree-stat__label">收获匣</text>
          </view>
        </view>
      </view>

      <view class="tree-panel">
        <view class="tree-panel__head">
          <view>
            <view class="tree-panel__title">{{treeStage.name}}</view>
            <view class="tree-panel__desc">{{treeStage.desc}}</view>
          </view>
          <view class="tree-panel__stage">第 {{treeStage.level}} 阶段</view>
        </view>

        <view class="tree-progress">
          <view class="tree-progress__text">{{treeStage.progressText}}</view>
          <view class="tree-progress__track">
            <view class="tree-progress__value" style="width: {{treeStage.progressPercent}}%;"></view>
          </view>
        </view>

        <view class="wish-tree wish-tree--stage{{treeStage.level}} {{!summary.total ? 'wish-tree--empty' : ''}}">
          <view class="wish-tree__halo"></view>
          <view class="wish-tree__crown wish-tree__crown--back"></view>
          <view class="wish-tree__crown wish-tree__crown--mid"></view>
          <view class="wish-tree__crown wish-tree__crown--front"></view>
          <view class="wish-tree__crown-fuzz wish-tree__crown-fuzz--1"></view>
          <view class="wish-tree__crown-fuzz wish-tree__crown-fuzz--2"></view>
          <view class="wish-tree__crown-fuzz wish-tree__crown-fuzz--3"></view>
          <view class="wish-tree__crown-fuzz wish-tree__crown-fuzz--4"></view>
          <view class="wish-tree__crown-shadow wish-tree__crown-shadow--1"></view>
          <view class="wish-tree__crown-shadow wish-tree__crown-shadow--2"></view>
          <view class="wish-tree__crown-shadow wish-tree__crown-shadow--3"></view>
          <view class="wish-tree__crown-shadow wish-tree__crown-shadow--4"></view>
          <view class="wish-tree__crown-shadow wish-tree__crown-shadow--5"></view>
          <view class="wish-tree__puff wish-tree__puff--1"></view>
          <view class="wish-tree__puff wish-tree__puff--2"></view>
          <view class="wish-tree__puff wish-tree__puff--3"></view>
          <view class="wish-tree__puff wish-tree__puff--4"></view>
          <view class="wish-tree__puff wish-tree__puff--5"></view>
          <view class="wish-tree__branch wish-tree__branch--left-a"></view>
          <view class="wish-tree__branch wish-tree__branch--right-a"></view>
          <view class="wish-tree__trunk"></view>
          <view class="wish-tree__trunk-line wish-tree__trunk-line--1"></view>
          <view class="wish-tree__trunk-line wish-tree__trunk-line--2"></view>
          <view class="wish-tree__trunk-line wish-tree__trunk-line--3"></view>
          <view class="wish-tree__trunk-line wish-tree__trunk-line--4"></view>
          <view class="wish-tree__ground"></view>
          <view class="wish-tree__flowerband">
            <view class="wish-tree__soil"></view>
            <view class="wish-tree__grass wish-tree__grass--1"></view>
            <view class="wish-tree__grass wish-tree__grass--2"></view>
            <view class="wish-tree__grass wish-tree__grass--3"></view>
            <view class="wish-tree__grass wish-tree__grass--4"></view>
            <view class="wish-tree__grass wish-tree__grass--5"></view>
            <view class="wish-tree__grass wish-tree__grass--6"></view>
            <view class="wish-tree__grass wish-tree__grass--7"></view>
            <view class="wish-tree__grass wish-tree__grass--8"></view>
            <view class="wish-tree__stem wish-tree__stem--1"></view>
            <view class="wish-tree__stem wish-tree__stem--2"></view>
            <view class="wish-tree__stem wish-tree__stem--3"></view>
            <view class="wish-tree__stem wish-tree__stem--4"></view>
            <view class="wish-tree__stem wish-tree__stem--5"></view>
            <view class="wish-tree__stem wish-tree__stem--6"></view>
            <view class="wish-tree__stem wish-tree__stem--7"></view>
            <view class="wish-tree__stem wish-tree__stem--8"></view>
          </view>
          <view class="wish-tree__badge">成熟的果实会优先挂在外侧枝头</view>

          <block wx:for="{{treeNodes}}" wx:key="id">
            <view class="wish-node wish-node--{{item.nodeType}} wish-node--slot{{item.treeSlot}} {{item.isExpanded ? 'wish-node--expanded' : ''}}">
              <view class="wish-node__tap" data-id="{{item.id}}" bindtap="toggleWishDetail">
                <view class="wish-node__stem"></view>
                <view wx:if="{{item.nodeType === 'bud'}}" class="wish-node__bud">
                  <view class="wish-node__bud-core"></view>
                </view>
                <view wx:elif="{{item.nodeType === 'ripe'}}" class="wish-node__fruit">
                  <view class="wish-node__fruit-shine"></view>
                </view>
                <view wx:if="{{item.nodeType === 'ripe'}}" class="wish-node__tip">可摘取</view>
              </view>

              <view wx:if="{{item.isExpanded}}" class="wish-card wish-card--tree">
                <view class="wish-card__tag">{{item.cardTag}}</view>
                <view class="wish-card__content">{{item.content}}</view>
                <view wx:if="{{item.completedTime}}" class="wish-card__date">完成于 {{item.completedTime}}</view>
                <view class="wish-card__actions">
                  <text wx:if="{{item.nodeType === 'bud'}}" class="wish-card__btn wish-card__btn--done" data-id="{{item.id}}" catchtap="toggleWish">完成</text>
                  <text wx:if="{{item.nodeType === 'ripe'}}" class="wish-card__btn wish-card__btn--store" data-id="{{item.id}}" catchtap="storeWishFruit">摘下收藏</text>
                  <text wx:if="{{item.nodeType === 'ripe'}}" class="wish-card__btn wish-card__btn--undo" data-id="{{item.id}}" catchtap="toggleWish">撤销</text>
                  <text class="wish-card__btn wish-card__btn--del" data-id="{{item.id}}" catchtap="removeWish">移除</text>
                </view>
              </view>
            </view>
          </block>

          <view wx:if="{{!summary.total}}" class="wish-tree__empty-note">第一颗花苞会挂在最亮的一根枝条上。</view>
        </view>
      </view>

      <view class="panel cabinet-panel">
        <view class="panel__title">🧺 收获匣</view>
        <view class="panel__desc">{{cabinetHint}}</view>

        <view class="cabinet-shell">
          <view class="cabinet-shell__top"></view>
          <view class="cabinet-shell__body">
            <view class="cabinet-shell__drawer"></view>
            <view class="cabinet-shell__knob cabinet-shell__knob--left"></view>
            <view class="cabinet-shell__knob cabinet-shell__knob--right"></view>
            <view wx:if="{{storedWishes.length}}" class="cabinet-list">
              <view wx:for="{{storedWishes}}" wx:key="id" class="cabinet-item {{item.isExpanded ? 'cabinet-item--expanded' : ''}}">
                <view class="cabinet-item__row" data-id="{{item.id}}" bindtap="toggleWishDetail">
                  <view class="cabinet-item__fruit"></view>
                  <view class="cabinet-item__main">
                    <view class="cabinet-item__title">{{item.content}}</view>
                    <view class="cabinet-item__meta">{{item.completedTime || '已成熟'}} · 已收入收获匣</view>
                  </view>
                </view>

                <view wx:if="{{item.isExpanded}}" class="wish-card wish-card--cabinet">
                  <view class="wish-card__tag">{{item.cardTag}}</view>
                  <view class="wish-card__content">{{item.content}}</view>
                  <view wx:if="{{item.completedTime}}" class="wish-card__date">完成于 {{item.completedTime}}</view>
                  <view class="wish-card__actions">
                    <text class="wish-card__btn wish-card__btn--restore" data-id="{{item.id}}" catchtap="restoreWishFruit">挂回树上</text>
                    <text class="wish-card__btn wish-card__btn--del" data-id="{{item.id}}" catchtap="removeWish">移除</text>
                  </view>
                </view>
              </view>
            </view>
            <view wx:else class="cabinet-empty">
              <view class="cabinet-empty__emoji">🍯</view>
              <view class="cabinet-empty__title">收获匣还是空的</view>
              <view class="cabinet-empty__desc">等树上的果实成熟后，可以摘下来慢慢收藏。</view>
            </view>
          </view>
          <view class="cabinet-shell__legs">
            <view class="cabinet-shell__leg cabinet-shell__leg--left"></view>
            <view class="cabinet-shell__leg cabinet-shell__leg--right"></view>
          </view>
        </view>
      </view>

      <view class="panel add-panel">
        <view class="panel__title">🌱 挂上新的心愿</view>
        <view class="panel__desc">可以是一次旅行、一顿晚餐，或者一个你们想一起认真完成的小计划。</view>
        <view class="editor-shell">
          <warm-input
            customClass="field-input"
            value="{{wishText}}"
            placeholder="例如：一起去海边看一次真正的日出"
            maxlength="40"
            bind:input="handleWishInput"
          ></warm-input>
          <view class="editor-shell__action">
            <warm-button theme="primary" size="large" bind:action="addWish">✨ 挂上枝头</warm-button>
          </view>
        </view>
      </view>

      <view class="warm-page-end"></view>
    </block>
  </view>
</view>