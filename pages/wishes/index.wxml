<warm-navbar title="心愿单"></warm-navbar>

<view class="wish-page">
  <warm-status-card wx:if="{{loading}}" title="🌸 正在整理心愿" desc="把想一起完成的小事和大事慢慢排出来。"></warm-status-card>

  <warm-status-card wx:elif="{{errorMessage}}" error="{{true}}" title="💭 加载失败" desc="{{errorMessage}}"></warm-status-card>

  <block wx:else>
    <view class="panel">
      <view class="panel__title">✨ 写下新的心愿</view>
      <view class="panel__desc">把想一起去、想一起做、想一起完成的小事都记下来。</view>
      <warm-input
        customClass="field-input"
        value="{{wishText}}"
        placeholder="例如：一起去看海"
        maxlength="40"
        bind:input="handleWishInput"
      ></warm-input>
      <warm-button theme="primary" size="large" bind:action="addWish">❤️ 新增心愿</warm-button>
    </view>

    <view class="panel">
      <view class="panel__title">🌷 心愿列表</view>
      <view wx:if="{{wishes.length}}" class="list-block">
        <view wx:for="{{wishes}}" wx:key="id" class="list-item">
          <view class="wish-meta" data-id="{{item.id}}" bindtap="toggleWish">
            <view class="wish-dot {{item.isCompleted ? 'wish-dot--done' : ''}}"></view>
            <view>
              <view class="list-item__title {{item.isCompleted ? 'is-done' : ''}}">{{item.content}}</view>
              <view class="list-item__desc">{{item.completedLabel}}</view>
            </view>
          </view>
          <text class="list-item__action" data-id="{{item.id}}" bindtap="removeWish">移除</text>
        </view>
      </view>

      <warm-empty-state wx:else customClass="list-empty" title="✨ 还没有心愿" desc="先写下第一个想一起完成的小目标。"></warm-empty-state>
    </view>
  </block>
</view>