<warm-navbar title="记录今天" left-arrow bind:left-click="goBack"></warm-navbar>

<view class="release-page warm-fade-page">
  <view class="release-hero">
    <view class="release-hero__eyebrow">❤️ 今天的回忆</view>
    <view class="release-hero__title">把这一刻温柔地保存下来</view>
    <view class="release-hero__desc">可以是一张照片、一句对话、一个心情，也可以只是今天很想记住你。</view>
  </view>

  <view class="panel">
    <view class="panel__title">📷 上传照片</view>
    <view class="panel__desc">最多可选择 9 张，把今天最想留住的画面放进来。</view>
    <view class="upload-grid">
      <view
        wx:for="{{imageFiles}}"
        wx:key="url"
        class="upload-item"
        data-index="{{index}}"
      >
        <image class="upload-item__image" src="{{item.url}}" mode="aspectFill" data-current="{{item.url}}" bindtap="previewImage" />
        <view class="upload-item__remove" data-index="{{index}}" bindtap="removeImage">移除</view>
      </view>

      <view wx:if="{{imageFiles.length < 9}}" class="upload-trigger" bindtap="chooseImages">
        <text class="upload-trigger__icon">🌸</text>
        <text class="upload-trigger__text">添加照片</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="field">
      <text class="field__label">✨ 标题</text>
      <warm-input
        customClass="field__input"
        value="{{title}}"
        placeholder="比如：一起吃晚饭"
        maxlength="20"
        bind:input="handleTitleInput"
      ></warm-input>
    </view>

    <view class="field">
      <text class="field__label">💌 内容</text>
      <textarea
        class="release-textarea"
        style="height: 420rpx; min-height: 420rpx;"
        value="{{content}}"
        placeholder="记录今天的感受、对方说的话、一个小瞬间"
        maxlength="300"
        auto-height="false"
        cursor-spacing="120"
        bindinput="handleContentInput"
      ></textarea>
    </view>

    <view class="field-row field-row--meta">
      <view class="field field--half">
        <text class="field__label">📅 日期</text>
        <view class="picker-shell">
          <view class="picker-value">{{recordDate}}</view>
          <picker class="picker-shell__native" mode="date" value="{{recordDate}}" bindchange="handleDateChange">
            <view class="picker-shell__hit"></view>
          </picker>
        </view>
      </view>

      <view class="field field--half">
        <text class="field__label">📍 地点</text>
        <view class="location-box {{location ? 'location-box--active' : ''}}">
          <view class="location-box__text">{{location ? location.name : '还没有标记地点'}}</view>
          <view class="location-box__actions">
            <text class="location-box__action" bindtap="chooseLocation">{{location ? '重选' : '选择'}}</text>
            <text wx:if="{{location}}" class="location-box__action location-box__action--muted" bindtap="clearLocation">清除</text>
          </view>
        </view>
      </view>
    </view>

    <view class="field field--mood field--mood-block">
      <text class="field__label">💗 心情</text>
      <view class="mood-list">
        <view
          wx:for="{{moods}}"
          wx:key="index"
          class="mood-chip {{index === selectedMoodIndex ? 'mood-chip--active' : ''}}"
          data-index="{{index}}"
          bindtap="selectMood"
        >
          {{item}}
        </view>
      </view>
      <warm-input
        wx:if="{{moods[selectedMoodIndex] === '自定义'}}"
        customClass="mood-custom-input"
        value="{{customMood}}"
        placeholder="写下此刻的心情，比如：有点想哭 / 心里堵堵的"
        maxlength="12"
        bind:input="handleCustomMoodInput"
      ></warm-input>
    </view>
  </view>

  <view class="action-bar">
    <view class="action-row">
      <view class="action-row__item">
        <view class="action-btn action-btn--draft" bindtap="saveDraft">
          <view class="action-btn__orb action-btn__orb--draft">
            <text class="action-btn__icon">🌷</text>
          </view>
          <view class="action-btn__copy">
            <text class="action-btn__text">保存草稿</text>
          </view>
        </view>
      </view>
      <view class="action-row__item">
        <view class="action-btn action-btn--primary {{saving ? 'action-btn--disabled' : ''}}" bindtap="publishMoment">
          <view class="action-btn__orb action-btn__orb--primary">
            <text class="action-btn__icon">❤️</text>
          </view>
          <view class="action-btn__copy">
            <text class="action-btn__text">{{saving ? '保存中...' : '保存回忆'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="warm-page-end"></view>
</view>