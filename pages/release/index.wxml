<t-navbar title="记录今天" left-arrow bind:left-click="goBack"></t-navbar>

<view class="release-page">
  <view class="panel">
    <view class="panel__title">上传照片</view>
    <view class="upload-grid">
      <view
        wx:for="{{imageFiles}}"
        wx:key="url"
        class="upload-item"
        data-index="{{index}}"
      >
        <image class="upload-item__image" src="{{item.url}}" mode="aspectFill" data-current="{{item.url}}" bindtap="previewImage" />
        <view class="upload-item__remove" data-index="{{index}}" bindtap="removeImage">删除</view>
      </view>

      <view wx:if="{{imageFiles.length < 9}}" class="upload-trigger" bindtap="chooseImages">
        <text class="upload-trigger__icon">+</text>
        <text class="upload-trigger__text">添加照片</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="field">
      <text class="field__label">标题</text>
      <input
        class="field__input"
        value="{{title}}"
        placeholder="比如：一起吃晚饭"
        maxlength="20"
        bindinput="handleTitleInput"
      />
    </view>

    <view class="field">
      <text class="field__label">内容</text>
      <textarea
        class="field__textarea"
        value="{{content}}"
        placeholder="记录今天的感受、对方说的话、一个小瞬间"
        maxlength="300"
        bindinput="handleContentInput"
      />
    </view>

    <view class="field-row">
      <view class="field field--half">
        <text class="field__label">日期</text>
        <picker mode="date" value="{{recordDate}}" bindchange="handleDateChange">
          <view class="picker-value">{{recordDate}}</view>
        </picker>
      </view>

      <view class="field field--half">
        <text class="field__label">心情</text>
        <view class="mood-list">
          <view
            wx:for="{{moods}}"
            wx:key="index"
            class="mood-chip {{index === selectedMoodIndex ? 'mood-chip--active' : ''}}"
            data-index="{{index}}"
            bindtap="selectMood"
          >
            {{item}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="action-row">
    <t-button theme="light" size="large" bindtap="saveDraft">存草稿</t-button>
    <t-button theme="primary" size="large" loading="{{saving}}" bindtap="publishMoment">保存到时光墙</t-button>
  </view>
</view>