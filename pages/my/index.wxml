<warm-navbar title="我们的空间" left-arrow bind:left-click="goBack"></warm-navbar>

<view class="space-page warm-fade-page">
  <warm-status-card wx:if="{{loading}}" title="🌸 正在装饰你们的空间" desc="把名字、介绍和统计慢慢摆放好。"></warm-status-card>

  <warm-status-card wx:elif="{{errorMessage}}" error="{{true}}" title="💭 加载失败" desc="{{errorMessage}}"></warm-status-card>

  <block wx:else>
  <view class="hero-card">
    <view class="hero-card__eyebrow">❤️ 我们的小天地</view>
    <view class="hero-card__title">{{profile.spaceName}}</view>
    <view class="hero-card__desc">{{profile.intro}}</view>
    <view class="hero-card__pair">{{profile.partnerA}} × {{profile.partnerB}}</view>
    <view class="hero-card__badge">🌷 一起把普通日子过成回忆</view>
  </view>

  <view class="stats-grid">
    <view class="stats-item">
      <text class="stats-item__value">{{stats.momentCount}}</text>
      <text class="stats-item__label">📷 回忆</text>
    </view>
    <view class="stats-item">
      <text class="stats-item__value">{{stats.anniversaryCount}}</text>
      <text class="stats-item__label">📅 纪念日</text>
    </view>
    <view class="stats-item">
      <text class="stats-item__value">{{stats.completedWishCount}} / {{stats.wishCount}}</text>
      <text class="stats-item__label">✨ 心愿</text>
    </view>
  </view>

  <view class="panel">
    <view class="panel__title">🌷 空间设置</view>
    <view class="panel__desc">可以在这里调整空间名字、双方昵称和介绍，让这个小程序更像你们自己。</view>
    <warm-input customClass="field-input" value="{{profile.spaceName}}" field="spaceName" maxlength="20" placeholder="空间名字" bind:input="handleInput"></warm-input>
    <warm-input customClass="field-input" value="{{profile.partnerA}}" field="partnerA" maxlength="10" placeholder="你的名字" bind:input="handleInput"></warm-input>
    <warm-input customClass="field-input" value="{{profile.partnerB}}" field="partnerB" maxlength="10" placeholder="对方名字" bind:input="handleInput"></warm-input>
    <warm-input textarea="{{true}}" customClass="field-textarea" field="intro" value="{{profile.intro}}" maxlength="80" minHeight="180rpx" placeholder="写一句只属于你们的介绍" bind:input="handleInput"></warm-input>
    <warm-button theme="primary" size="large" bind:action="saveProfile">❤️ 保存空间信息</warm-button>
  </view>

  <view class="panel panel--danger">
    <view class="panel__title">🫧 数据管理</view>
    <view class="panel__desc">当前版本已经接入云开发数据库，清空后会同步删除云端回忆、纪念日、心愿和上传图片。</view>
    <warm-button theme="danger" variant="outline" size="large" bind:action="clearAllData">清空云端数据</warm-button>
  </view>

  <view class="warm-page-end"></view>

  </block>
</view>
